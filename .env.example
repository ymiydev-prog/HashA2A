# Hedera Operator Credentials
HEDERA_OPERATOR_ID=0.0.1234567
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...
HEDERA_NETWORK=testnet

# Treasury account that receives HBAR payments
TREASURY_ACCOUNT=0.0.1234567
TREASURY_PRIVATE_KEY=302e020100300506032b657004220420...

# Mirror Node (public endpoint, no auth needed)
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# Hashgraph Online (HOL) Registry topic for HCS-10 discovery
HOL_REGISTRY_TOPIC=0.0.29640405

# HIP-991: Custom Fees on HCS Inbound Topic
# When an agent submits a message, the fee is auto-collected.
HIP991_FEE_HBAR=0.5
HIP991_FEE_COLLECTOR=0.0.1234567

# Payment expiry
PAYMENT_TTL_SECONDS=300
REQUEST_EXPIRY_SECONDS=3600

# AI / LangChain (optional)
OPENAI_API_KEY=sk-...
LANGCHAIN_MODEL=gpt-4o-mini
LANGCHAIN_TEMPERATURE=0.3

# Agent identity (used for self-promotion / HCS-10 broadcasts)
AGENT_NAME=HashA2A Intelligence Oracle
AGENT_DESCRIPTION=Modular data oracle where agents buy AI-processed intelligence via HBAR micropayments
AGENT_VERSION=0.2.0
AGENT_TAGS=["data-oracle","intelligence","hedera","ai","prediction-markets"]
AGENT_PROMOTIONAL_INTERVAL=3600

# API
API_HOST=0.0.0.0
API_PORT=8080

# X/Twitter Auto-Promotion (optional)
# Get credentials from https://developer.twitter.com
# TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAA...
# TWITTER_API_KEY=abc123...
# TWITTER_API_SECRET=def456...
# TWITTER_ENABLED=true
